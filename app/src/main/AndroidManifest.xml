<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Notification poll (E7) — Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".QaApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.QaWorkspace">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.QaWorkspace">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- App Links auth redirect (E2, D2a): server hands back the session token at
                 https://baokim-qa.com/app/auth#token=... . autoVerify checks ownership via
                 /.well-known/assetlinks.json (fingerprints in backend .env, see SIGNING.md). -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https"
                    android:host="baokim-qa.com"
                    android:path="/app/auth" />
            </intent-filter>
        </activity>

        <!-- Swipe-away on an activity notification → mark read server-side (E7.3). -->
        <receiver
            android:name=".data.notify.DismissReceiver"
            android:exported="false" />

        <!-- Exported bug-log .xlsx lives in cache/exports and is shared via a chooser (E8.5).
             Grants are per-Intent (FLAG_GRANT_READ_URI_PERMISSION); nothing is world-readable. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- On-demand WorkManager (E7): disable the default startup initializer so the app's
             Configuration.Provider (QaApp) supplies the HiltWorkerFactory. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>
</manifest>
